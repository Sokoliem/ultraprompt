{
  "schema_version": 1,
  "release_track": "v8-cognitive-control-plane",
  "sources": {
    "skills": "source/skill-specs.json",
    "agents": "source/agent-specs.json",
    "panels": "source/panel-specs.json",
    "dream_jobs": "source/dream-jobs.json",
    "memory_schemas": "source/memory-schemas.json",
    "hooks": "hooks/hooks.json",
