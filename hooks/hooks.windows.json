{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/session-bootstrap.py\"",
            "timeout": 8
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/user-prompt-route-suggest.py\"",
            "timeout": 4
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/skill-agent-telemetry.py\"",
            "timeout": 3
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/destructive-command-guard.py\""
          }
        ]
      },
      {
        "matcher": "Write|Edit|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/protected-file-guard.py\""
          }
        ]
      }
    ],
    "SubagentStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/subagent-scaffold.py\"",
            "timeout": 5
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/auto-wip-save.py\"",
            "timeout": 30
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/stop-validation-check.py\"",
            "timeout": 10
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "py -3 \"${CLAUDE_PLUGIN_ROOT}/hooks/recipes/session-finalize.py\"",
            "timeout": 8
          }
        ]
      }
    ]
  }
}
